flowchart TD
  %% === ENTRY & PRE-CHECKS ===
  A[User selects <b>Hotel</b> under Crew Logistics] --> B{AIMS: Duty = Layover <br/>AND<br/>(Next 12h OR Arrived within last 24h)?}
  B -- No --> Z1[Outside window → Advisory / visit Policy or iCrew]
  B -- Yes --> C{HOTAC Status}

  %% === BRANCH: HOTAC CONFIRMED ===
  C -- Confirmed --> B1[Show <b>Crew Logistics App</b> link + info msg <br/>No agent]

  %% === BRANCH: HOTAC PENDING / REJECTED ===
  C -- Pending / Rejected --> D{Arrived in last 1–2h?}
  D -- Yes --> B2[<b>Transfer to Agent</b> immediately]
  D -- No --> B3[Info msg + <b>Create Ticket</b>]

  %% === BRANCH: NO HOTEL FOUND ===
  C -- Not Found --> E{Check: International / Halt / Transport}

  subgraph "International Station — Day Use"
    direction TB
    E -- Intl & Halt < 4h --> B4[Not authorized at Intl <br/><b>Show Policy</b>; No ticket]
    E -- Intl & Halt ≥ 4h --> B5[Day-use not arranged at Intl <br/>Allowances → forex card <br/><b>Show Policy</b>]
  end

  subgraph "Transport Entry Only"
    direction TB
    E -- Transport entry found & Arrived < 2h --> B6[Local transport flow <br/><b>Show App</b> link]
  end

  subgraph "Domestic — Day Use Eligibility"
    direction TB
    E -- Domestic / Not Intl --> F{Halt < 4h?}
    F -- Yes --> F1[Not authorized < 4h <br/><b>Show Policy</b> · Back to menu]
    F -- No (≥ 4h) --> G{HOTAC Confirmed / Pending?}
    G -- Yes --> G1[Day-use arranged / details in <b>App</b>]
    G -- No (Rejected / Not Found) --> H{Arrived?}
    H -- Yet to arrive --> H1[<b>Create Ticket</b>]
    H -- Arrived ≤ 1h --> H2[<b>Transfer to Agent</b>]
  end

  %% === TRAINING RULES ===
  subgraph "Training Rules"
    direction TB
    T0{Crew Type?}
    T0 -- Training Cabin --> T1[Day-use NOT authorized for Training Cabin <br/><b>Show Policy</b>]
    T0 -- Training Cockpit --> T2{Halt ≥ 4h?}
    T2 -- No (< 4h) --> T2c[Not authorized < 4h <br/><b>Show Policy</b>]
    T2 -- Yes & HOTAC Conf/Pend --> T2a[Details in <b>App</b>]
    T2 -- Yes & HOTAC Rej/NotFound --> T2b{Arrived?}
    T2b -- Yet to arrive --> T2b1[<b>Create Ticket</b>]
    T2b -- Arrived ≤ 1h --> T2b2[<b>Transfer to Agent</b>]
  end

  %% === CAB NOT RECEIVED ===
  subgraph "Hotel Cab Not Received"
    direction TB
    CN[Cab Not Received] --> CNA{Direction?}
    CNA -- Airport → Hotel --> CNAa{HOTAC & Arrival}
    CNAa -- Confirmed & Arrived < 2h --> CNA1[Ask: Contacted hotel coord # ? <br/>Capture outcome → <b>Transfer to Agent</b>]
    CNAa -- Pending/Rejected OR No hotel & Arrived < 2h --> CNA2[<b>Transfer to Agent</b> immediately]
    CNAa -- No hotel + Transport entry & Arrived < 2h --> CNA3[Local transport guidance <br/><b>Show App</b> link]

    CNA -- Hotel → Airport/Training --> CNB{Destination?}
    CNB -- Airport --> CNB1[<b>Transfer to Agent</b> immediately]
    CNB -- Training/Office --> CNB2[<b>Create Ticket</b>; if < 2h to reporting → also <b>Transfer</b>]
  end

  %% === ISSUE IN HOTEL (9 OPTIONS) ===
  subgraph "Issue / Need Assistance in Hotel"
    direction TB
    IH[Hygiene/Noise · Waiting for Room · Bed Type · Laundry · Staff Behaviour · Meals · Incident/Safety · Payment · Any Other]
    IH --> IH1[Universal: <b>Transfer to Agent</b> immediately]
  end

  %% === CAB CLUBBING (CABIN ONLY) ===
  subgraph "Cab Clubbing (Cabin only)"
    direction TB
    CC[Cab size/luggage not fitting] --> CC1[<b>Transfer to Agent</b>]
  end

  %% === STAY EXTENSION ===
  subgraph "Hotel Stay Extension"
    direction TB
    SE[Request Stay Extension] --> SE0{Relocation Cabin (RLLH)?}
    SE0 -- Yes --> SE1[IFS Base Head/Admin <br/>approval mandatory at <br/>crew.logistics@goindigo.in <br/>No processing till received]
    SE0 -- No --> SE2[<b>Create Ticket</b>]
  end

  %% === REIMBURSEMENT & FEEDBACK ===
  subgraph "Reimbursement & Feedback"
    direction TB
    RF[Open R&F] --> R1[Reimbursement (All): <b>Create Ticket</b> + allow attachments]
    RF --> R2{Feedback Crew Type?}
    R2 -- Cockpit --> R2a[Provide Feedback Form URL · Close]
    R2 -- Cabin --> R2b[<b>Create Ticket</b>]
  end

  %% === ESCALATION GUIDANCE (LEGEND) ===
  classDef act fill:#E6F4EA,stroke:#1e8e3e,stroke-width:1px,color:#000
  classDef info fill:#E8F0FE,stroke:#1967d2,stroke-width:1px,color:#000
  classDef warn fill:#FFF4E5,stroke:#c26400,stroke-width:1px,color:#000
  class B1,G1,B6,R2a act
  class B3,H1,T2b1,R1 info
  class B2,H2,T2b2,CNB1,CNA2,IH1,CC1 act
  class B4,B5,F1,T1,T2c warn

