@mcp.tool(tags=["FlightRead"])
async def count_flights_by_service_category(
    carrier: str = "",
    start_date: str = "",
    end_date: str = "",
    service_category: str = "ALL",  # "SCHEDULED", "CHARTER", "CARGO", or "ALL"
    startStation: Optional[str] = None,
    endStation: Optional[str] = None,
    include_breakdown: bool = True
) -> str:
    """
    Count flights by service type categories according to business rules.
    
    Business Rules:
    - Scheduled Flight: serviceType = ["J", "S", "B", "G"] 
    - Charter Flight: serviceType = ["C", "E", "I", "L", "O", "Q", "R", "W"]
    - Cargo Flight: serviceType = ["A", "F", "H", "V", "M"]
    
    Args:
        carrier: Optional airline carrier filter (e.g., "6E")
        start_date: Start date in YYYY-MM-DD format (required)
        end_date: End date in YYYY-MM-DD format (required)
        service_category: Filter by category - "SCHEDULED", "CHARTER", "CARGO", or "ALL"
        startStation: Optional departure station filter
        endStation: Optional arrival station filter
        include_breakdown: Include detailed breakdown by service codes
    
    Returns:
        JSON with flight counts by service category
    """
    logger.info(f"count_flights_by_service_category: carrier={carrier}, category={service_category}, dates={start_date} to {end_date}")
    
    if not start_date or not end_date:
        return response_error("start_date and end_date are required", 400)
    
    sd = validate_date(start_date)
    ed = validate_date(end_date)
    if not sd or not ed:
        return response_error("Invalid date format. Expected YYYY-MM-DD", 400)
    
    # Build base query
    match_stage = {
        "flightLegState.dateOfOrigin": {"$gte": sd, "$lte": ed},
        "flightLegState.handling.serviceType": {"$exists": True, "$ne": None}
    }
    
    if carrier:
        match_stage["flightLegState.carrier"] = carrier
    if startStation:
        match_stage["flightLegState.startStation"] = startStation
    if endStation:
        match_stage["flightLegState.endStation"] = endStation
    
    # Service type mappings
    service_mappings = {
        "SCHEDULED": ["J", "S", "B", "G"],
        "CHARTER": ["C", "E", "I", "L", "O", "Q", "R", "W"], 
        "CARGO": ["A", "F", "H", "V", "M"]
    }
    
    try:
        _, _, col = await get_mongodb_client()
        
        # If filtering by specific category
        if service_category != "ALL" and service_category in service_mappings:
            match_stage["flightLegState.handling.serviceType"] = {"$in": service_mappings[service_category]}
            
            count = await col.count_documents(match_stage)
            
            result = {
                "requestedCategory": service_category,
                "flightCount": count,
                "serviceCodes": service_mappings[service_category],
                "dateRange": f"{sd} to {ed}",
                "carrier": carrier if carrier else "All carriers",
                "route": f"{startStation} → {endStation}" if startStation and endStation else "All routes",
                "query": match_stage
            }
            
            if include_breakdown and count > 0:
                # Get breakdown by service codes within the category
                pipeline = [
                    {"$match": match_stage},
                    {"$group": {
                        "_id": "$flightLegState.handling.serviceType",
                        "count": {"$sum": 1}
                    }},
                    {"$sort": {"count": -1}}
                ]
                
                breakdown_results = await col.aggregate(pipeline).to_list(length=20)
                breakdown = {}
                for item in breakdown_results:
                    code = item.get("_id")
                    count_val = item.get("count", 0)
                    description = FLIGHT_SERVICE_CODES.get(code, "Description not available")
                    breakdown[code] = {
                        "count": count_val,
                        "description": description
                    }
                
                result["serviceCodeBreakdown"] = breakdown
            
            logger.info(f" {service_category} flights count: {count}")
            return response_ok(result)
        
        # Count ALL categories
        else:
            # Use aggregation to count all categories at once
            pipeline = [
                {"$match": match_stage},
                {"$group": {
                    "_id": "$flightLegState.handling.serviceType",
                    "count": {"$sum": 1}
                }}
            ]
            
            results = await col.aggregate(pipeline).to_list(length=30)
            
            # Classify results
            category_counts = {
                "SCHEDULED": {"count": 0, "codes": {}},
                "CHARTER": {"count": 0, "codes": {}},
                "CARGO": {"count": 0, "codes": {}},
                "OTHER": {"count": 0, "codes": {}}
            }
            
            total_flights = 0
            
            for item in results:
                code = item.get("_id", "")
                count_val = item.get("count", 0)
                total_flights += count_val
                
                # Classify the service code
                category = "OTHER"  # Default
                if code in service_mappings["SCHEDULED"]:
                    category = "SCHEDULED"
                elif code in service_mappings["CHARTER"]:
                    category = "CHARTER"
                elif code in service_mappings["CARGO"]:
                    category = "CARGO"
                
                # Update category count
                category_counts[category]["count"] += count_val
                
                # Store code details if requested
                if include_breakdown:
                    description = FLIGHT_SERVICE_CODES.get(code, "Description not available")
                    category_counts[category]["codes"][code] = {
                        "count": count_val,
                        "description": description
                    }
            
            # Calculate percentages
            for category in category_counts:
                if total_flights > 0:
                    category_counts[category]["percentage"] = round(
                        (category_counts[category]["count"] / total_flights * 100), 2
                    )
                else:
                    category_counts[category]["percentage"] = 0.0
            
            result = {
                "totalFlights": total_flights,
                "flightCounts": {
                    "scheduled": category_counts["SCHEDULED"]["count"],
                    "charter": category_counts["CHARTER"]["count"],
                    "cargo": category_counts["CARGO"]["count"],
                    "other": category_counts["OTHER"]["count"]
                },
                "flightPercentages": {
                    "scheduled": category_counts["SCHEDULED"]["percentage"],
                    "charter": category_counts["CHARTER"]["percentage"],
                    "cargo": category_counts["CARGO"]["percentage"],
                    "other": category_counts["OTHER"]["percentage"]
                },
                "businessRules": {
                    "scheduled": "serviceType in ['J', 'S', 'B', 'G']",
                    "charter": "serviceType in ['C', 'E', 'I', 'L', 'O', 'Q', 'R', 'W']",
                    "cargo": "serviceType in ['A', 'F', 'H', 'V', 'M']"
                },
                "dateRange": f"{sd} to {ed}",
                "carrier": carrier if carrier else "All carriers",
                "route": f"{startStation} → {endStation}" if startStation and endStation else "All routes",
                "categoryBreakdown": category_counts if include_breakdown else None,
                "query": match_stage
            }
            
            logger.info(f"Service type counts - Scheduled: {category_counts['SCHEDULED']['count']}, "
                       f"Charter: {category_counts['CHARTER']['count']}, "
                       f"Cargo: {category_counts['CARGO']['count']}, "
                       f"Other: {category_counts['OTHER']['count']}")
            
            return response_ok(result)
        
    except Exception as exc:
        logger.exception("Service type counting failed")
        return response_error(f"Service type counting failed: {str(exc)}", 500)
