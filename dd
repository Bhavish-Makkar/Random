@mcp.tool(tags=["FlightRead"])
async def get_delay_reasons_breakdown(
    carrier: str = "",
    flight_number: int = 0,
    date_of_origin: str = "",
    start_date: str = "",
    end_date: str = "",
    startStation: Optional[str] = None,
    endStation: Optional[str] = None,
    include_total_only_delays: bool = True,
    limit: int = 100
) -> str:
    """
    Extract delay reasons and remarks from flights with detailed descriptions.
    Enriches delay reason codes with human-readable descriptions from delay codes database.
    
    Args:
        carrier: Optional airline carrier filter (e.g., "6E")
        flight_number: Optional flight number filter (e.g., 215)
        date_of_origin: Optional single date filter (YYYY-MM-DD)
        start_date: Optional start date for range (YYYY-MM-DD)
        end_date: Optional end date for range (YYYY-MM-DD)
        startStation: Optional departure station filter (e.g., "DEL")
        endStation: Optional arrival station filter (e.g., "BOM")
        include_total_only_delays: Include flights with only total delay (default: True)
        limit: Maximum number of flights to analyze (default: 100)
    
    Returns:
        JSON with enhanced delay breakdown including reason codes, descriptions, and remarks
    """
    logger.info(f"get_delay_reasons_breakdown: carrier={carrier}, flight={flight_number}, date={date_of_origin}")
    
    # Build match stage
    match_stage = {}
    
    if carrier:
        match_stage["flightLegState.carrier"] = carrier
    if flight_number:
        fn = normalize_flight_number(flight_number)
        if fn:
            match_stage["flightLegState.flightNumber"] = fn
    
    # Date filtering
    if start_date and end_date:
        sd = validate_date(start_date)
        ed = validate_date(end_date)
        if sd and ed:
            match_stage["flightLegState.dateOfOrigin"] = {"$gte": sd, "$lte": ed}
    elif date_of_origin:
        dob = validate_date(date_of_origin)
        if dob:
            match_stage["flightLegState.dateOfOrigin"] = dob
    
    if startStation:
        match_stage["flightLegState.startStation"] = startStation
    if endStation:
        match_stage["flightLegState.endStation"] = endStation
    
    # Look for flights with ANY delay (detailed or total only)
    if include_total_only_delays:
        match_stage["$or"] = [
            {"flightLegState.delays.delay": {"$exists": True, "$ne": []}},
            {"flightLegState.delays.total": {"$nin": ["PT0H0M", "00:00", "", None, "0"]}}
        ]
    else:
        match_stage["flightLegState.delays.delay"] = {"$exists": True, "$ne": []}
    
    pipeline = [
        {"$match": match_stage},
        {"$limit": limit},
        {
            "$project": {
                "_id": 0,
                "carrier": "$flightLegState.carrier",
                "flightNumber": "$flightLegState.flightNumber",
                "dateOfOrigin": "$flightLegState.dateOfOrigin",
                "startStation": "$flightLegState.startStation",
                "endStation": "$flightLegState.endStation",
                "scheduledStartTime": "$flightLegState.scheduledStartTime",
                "totalDelay": "$flightLegState.delays.total",
                "delayDetails": "$flightLegState.delays.delay"
            }
        }
    ]
    
    try:
        _, _, col = await get_mongodb_client()
        logger.info(f"Running delay reasons aggregation: {json.dumps(pipeline, indent=2)}")
        
        results = await col.aggregate(pipeline).to_list(length=limit)
        
        if not results:
            return response_error("No delayed flights found for the given criteria.", 404)
        
        processed_flights = []
        flights_without_detailed_reasons = []
        reason_summary = {}
        
        for flight in results:
            flight_delays = []
            delay_details = flight.get("delayDetails", []) or []
            total_delay = flight.get("totalDelay", "PT0H0M")
            
            # Process flights with detailed delay reasons
            if delay_details and len(delay_details) > 0:
                for delay in delay_details:
                    reason_code = delay.get("reason")
                    remark = delay.get("remark", "")
                    
                    # ENHANCED: Get description from JSON lookup
                    description = get_delay_description(reason_code)
                    
                    # ENHANCED: Combine reason + description + remark
                    enhanced_reason = f"{reason_code} - {description}"
                    if remark:
                        final_delay_info = f"{enhanced_reason} | Remark: {remark}"
                    else:
                        final_delay_info = enhanced_reason
                    
                    delay_info = {
                        "time": delay.get("time"),
                        "reasonCode": reason_code,
                        "description": description,
                        "remark": remark,
                        "enhancedReason": enhanced_reason,
                        "finalDelayInfo": final_delay_info,  # This is the main output
                        "delayNumber": delay.get("delayNumber"),
                        "isRootCause": delay.get("isRootCause", False)
                    }
                    flight_delays.append(delay_info)
                    
                    # Track for summary
                    if reason_code:
                        if reason_code not in reason_summary:
                            reason_summary[reason_code] = {
                                "description": description,
                                "examples": []
                            }
                        if len(reason_summary[reason_code]["examples"]) < 3:
                            reason_summary[reason_code]["examples"].append({
                                "remark": remark,
                                "time": delay.get("time"),
                                "flight": f"{flight.get('carrier')}{flight.get('flightNumber')}",
                                "route": f"{flight.get('startStation')} → {flight.get('endStation')}",
                                "finalDelayInfo": final_delay_info
                            })
            
            # Handle flights with total delay but no detailed reasons
            elif total_delay and total_delay not in ["PT0H0M", "00:00", "", "0"]:
                enhanced_reason = "UNSPECIFIED - No specific delay reason provided"
                final_delay_info = f"{enhanced_reason} | Total Delay: {total_delay}"
                
                flight_delays.append({
                    "time": total_delay,
                    "reasonCode": "UNSPECIFIED",
                    "description": "No specific delay reason provided",
                    "remark": "Only total delay available",
                    "enhancedReason": enhanced_reason,
                    "finalDelayInfo": final_delay_info,
                    "delayNumber": 1,
                    "isRootCause": None
                })
                
                flights_without_detailed_reasons.append({
                    "flight": f"{flight.get('carrier')}{flight.get('flightNumber')}",
                    "date": flight.get("dateOfOrigin"),
                    "route": f"{flight.get('startStation')} → {flight.get('endStation')}",
                    "totalDelay": total_delay,
                    "finalDelayInfo": final_delay_info
                })
                
                if "UNSPECIFIED" not in reason_summary:
                    reason_summary["UNSPECIFIED"] = {
                        "description": "No specific delay reason provided",
                        "examples": []
                    }
            
            # Add to processed flights
            processed_flights.append({
                "flight": f"{flight.get('carrier')}{flight.get('flightNumber')}",
                "date": flight.get("dateOfOrigin"),
                "route": f"{flight.get('startStation')} → {flight.get('endStation')}",
                "scheduledStartTime": flight.get("scheduledStartTime"),
                "totalDelay": total_delay,
                "numberOfDelays": len(flight_delays),
                "delays": flight_delays,
                "hasDetailedReasons": len(delay_details) > 0,
                # ENHANCED: Summary of all delay info for this flight
                "allDelaysSummary": " | ".join([d["finalDelayInfo"] for d in flight_delays])
            })
        
        # ENHANCED: Create enriched reason summary
        enriched_reason_summary = []
        for code, data in reason_summary.items():
            enriched_reason_summary.append({
                "reasonCode": code,
                "description": data["description"],
                "enhancedReason": f"{code} - {data['description']}",
                "exampleCount": len(data["examples"]),
                "examples": data["examples"]
            })
        
        result = {
            "summary": {
                "totalFlights": len(processed_flights),
                "flightsWithDetailedReasons": len(processed_flights) - len(flights_without_detailed_reasons),
                "flightsWithOnlyTotalDelay": len(flights_without_detailed_reasons),
                "uniqueDelayReasons": len(reason_summary),
                "availableReasonCodes": list(reason_summary.keys())
            },
            "flightDetails": processed_flights,
            "flightsWithoutDetailedReasons": flights_without_detailed_reasons,
            "enrichedReasonSummary": enriched_reason_summary,  # Enhanced summary
            "delayCodesUsed": len(DELAY_CODES_LOOKUP),  # Info about loaded delay codes
            "query": match_stage
        }
        
        logger.info(f"Enhanced delay analysis: {len(processed_flights)} total flights, "
                   f"{len(flights_without_detailed_reasons)} without detailed reasons, "
                   f"using {len(DELAY_CODES_LOOKUP)} delay code descriptions")
        return response_ok(result)
        
    except Exception as exc:
        logger.exception("get_delay_reasons_breakdown failed")
        return response_error(f"Enhanced delay analysis failed: {str(exc)}", 500)


