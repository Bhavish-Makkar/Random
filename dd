            flight_status = flight.get("flightStatus")
            start_station = flight.get("startStation")
            date = flight.get("dateOfOrigin")
            
            # Count by status type
            if flight_status in status_breakdown:
                status_breakdown[flight_status] += 1
            
            # Track by departure station
            if start_station:
                if start_station not in stations_summary:
                    stations_summary[start_station] = {"total": 0, "DV": 0, "DH": 0}
                stations_summary[start_station]["total"] += 1
                if flight_status in ["DV", "DH"]:
                    stations_summary[start_station][flight_status] += 1
            
            # Track by date
            if date:
                if date not in daily_summary:
                    daily_summary[date] = {"total": 0, "DV": 0, "DH": 0}
                daily_summary[date]["total"] += 1
                if flight_status in ["DV", "DH"]:
                    daily_summary[date][flight_status] += 1
            
            # Calculate flight duration if possible
            takeoff_time = flight.get("actualTakeoffTime")
            landing_time = flight.get("actualLandingTime")
            flight_duration = None
            
            if takeoff_time and landing_time:
                try:
                    takeoff_dt = datetime.fromisoformat(takeoff_time.replace("Z", "+00:00"))
                    landing_dt = datetime.fromisoformat(landing_time.replace("Z", "+00:00"))
                    duration_minutes = int((landing_dt - takeoff_dt).total_seconds() / 60)
                    flight_duration = format_minutes_to_readable(duration_minutes)
                except:
                    pass
            
            diverted_flights_breakdown.append({
                "flight": f"{flight.get('carrier')}{flight.get('flightNumber')}",
                "date": date,
                "originalRoute": f"{start_station} → {flight.get('endStation')}",
                "scheduledDeparture": flight.get("scheduledStartTime"),
                "actualDeparture": flight.get("actualOffBlock"),
                "actualTakeoff": takeoff_time,
                "actualLanding": landing_time,
                "flightDuration": flight_duration,
                "flightStatus": flight_status,
                "statusDescription": {
                    "DV": "Diverted",
                    "DH": "Diversion Handling"
                }.get(flight_status, flight_status),
                "aircraftRegistration": flight.get("aircraftRegistration")
            })
        
        result = {
            "divertedFlightsAnalysis": {
                "totalDivertedFlights": total_diverted_flights,
                "dateRange": f"{sd} to {ed}",
                "carrier": carrier if carrier else "All carriers",
                "route": f"{startStation} → {endStation}" if startStation and endStation else "All routes",
                "businessRules": {
                    "actualTakeoffTime": "not null (Flight took off)",
                    "actualOffBlock": "not null (Departed from gate)",
                    "flightStatus": "DV (Diverted) or DH (Diversion Handling)"
                }
            },
            "statusBreakdown": {
                "diverted": status_breakdown.get("DV", 0),
                "diversionHandling": status_breakdown.get("DH", 0),
                "total": total_diverted_flights
            },
            "stationBreakdown": dict(sorted(stations_summary.items(), key=lambda x: x[1]["total"], reverse=True)),
            "dailyBreakdown": dict(sorted(daily_summary.items())),
            "divertedFlightsDetails": diverted_flights_breakdown if include_breakdown else [],
            "totalFlightsAnalyzed": len(diverted_flights_breakdown),
            "query": match_stage
        }
        
        logger.info(f"Diverted flights analysis: {total_diverted_flights} diverted flights (DV: {status_breakdown.get('DV', 0)}, DH: {status_breakdown.get('DH', 0)})")
        return response_ok(result)
        
    except Exception as exc:
        logger.exception("Diverted flights analysis failed")
        return response_error(f"Diverted flights analysis failed: {str(exc)}", 500)

@mcp.tool(tags=["FlightRead"])
async def count_diverted_flights(
    carrier: str = "",
    start_date: str = "",
    end_date: str = "",
    startStation: Optional[str] = None,
    endStation: Optional[str] = None
) -> str:
    """
    Count diverted flights according to business rules.
    
    Business Rules for Diverted Flight:
    1. operation.actualTimes.takeoffTime is not null (flight took off)
    2. Qualifies as "Departed Flight" (actualTimes.offBlock is recorded)
    3. flightStatus is "DV" (Diverted) or "DH" (Diversion Handling)
    
    Args:
        carrier: Optional airline carrier filter (e.g., "6E")
        start_date: Start date in YYYY-MM-DD format (required)
        end_date: End date in YYYY-MM-DD format (required)
        startStation: Optional departure station filter
        endStation: Optional arrival station filter
    
    Returns:
        JSON with diverted flights count
    """
    logger.info(f"count_diverted_flights: carrier={carrier}, dates={start_date} to {end_date}")
    
    if not start_date or not end_date:
        return response_error("start_date and end_date are required", 400)
    
    sd = validate_date(start_date)
    ed = validate_date(end_date)
    if not sd or not ed:
        return response_error("Invalid date format", 400)
    
    match_stage = {
        "flightLegState.dateOfOrigin": {"$gte": sd, "$lte": ed},
        "flightLegState.flightStatus": {"$in": ["DV", "DH"]},
        "flightLegState.operation.actualTimes.takeoffTime": {"$exists": True, "$ne": None},
        "flightLegState.operation.actualTimes.offBlock": {"$exists": True, "$ne": None}
    }
    
    if carrier:
        match_stage["flightLegState.carrier"] = carrier
    if startStation:
        match_stage["flightLegState.startStation"] = startStation.upper()
    if endStation:
        match_stage["flightLegState.endStation"] = endStation.upper()
    
    try:
        _, _, col = await get_mongodb_client()
        count = await col.count_documents(match_stage)
        
        result = {
            "divertedFlightsCount": count,
            "dateRange": f"{sd} to {ed}",
            "carrier": carrier if carrier else "All carriers",
            "route": f"{startStation} → {endStation}" if startStation and endStation else "All routes",
            "businessRules": {
                "actualTakeoffTime": "not null (Flight took off)",
                "actualOffBlock": "not null (Departed from gate)",
                "flightStatus": "DV (Diverted) or DH (Diversion Handling)"
            }
        }
        
        logger.info(f"Diverted flights count: {count}")
        return response_ok(result)
        
    except Exception as exc:
        logger.exception("Count diverted flights failed")
        return response_error(f"Count diverted flights failed: {str(exc)}", 500)

