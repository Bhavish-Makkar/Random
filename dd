def load_delay_codes():
    """Load delay codes from JSON file"""
    try:
        json_path = Path(__file__).parent / "Delay_Reason_JOC_Output.json"
        logger.info(f"Loading delay codes from: {json_path}")
        with open(json_path, 'r', encoding='utf-8') as f:
            data = json.load(f)
            # Create lookup dictionary: reason_id -> description
            delay_lookup = {}
            for delay_code in data.get("delayCodes", {}).get("delayCode", []):
                if "id" in delay_code and "description" in delay_code:
                    delay_lookup[delay_code["id"]] = delay_code["description"]
            logger.info(f"✅ Loaded {len(delay_lookup)} delay codes successfully")
            return delay_lookup
    except Exception as e:
        logger.warning(f"Could not load delay codes JSON: {e}")
        return {}

