        if cnl_codes_path.exists():
            with open(cnl_codes_path, 'r', encoding='utf-8') as f:
                data = json.load(f)
                # Create lookup dictionary: cancellation_id -> description
                cnl_lookup = {}
                for cnl_reason in data.get("cnlReasons", {}).get("cancellationReason", []):
                    cnl_lookup[cnl_reason.get("id", "")] = cnl_reason.get("description", "")
                logger.info(f"Loaded {len(cnl_lookup)} cancellation codes successfully")
