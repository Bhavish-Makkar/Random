import fitz  # PyMuPDF
from openai import AzureOpenAI

client=AzureOpenAI(
    api_key="",
    api_version="2024-02-15-preview",
    azure_endpoint="
)
def extract_text_from_pdf(pdf_path):
    doc = fitz.open(pdf_path)
    pages = []
    
    for i, page in enumerate(doc):
        text = page.get_text("text")
        pages.append({
            "page": i + 1,
            "text": text
        })
    output_path="Fosa.txt"
    with open(output_path, "w", encoding="utf-8") as f:
                for page in pages:
                    f.write(f"\n===== PAGE {page['page']} =====\n")
                    f.write(page["text"])
                    f.write("\n")

    return pages

import re
 
def split_into_sections(pages):
    sections = []
    current_section = {
        "title": "UNKNOWN",
        "content": "",
        "page_start": 1
    }
 
    heading_pattern = re.compile(
        r'^(SECTION\s+\d+.*|[A-Z][A-Z\s\-()]{5,}:)$'
    )
 
    for page in pages:
        lines = page["text"].split("\n")
 
        for line in lines:
            line = line.strip()
 
            if not line:
                continue
 
            if heading_pattern.match(line):
                # Save previous section
                if current_section["content"]:
                    sections.append(current_section)
 
                current_section = {
                    "title": line,
                    "content": "",
                    "page_start": page["page"]
                }
            else:
                current_section["content"] += line + "\n"
 
    # Add last section
    if current_section["content"]:
        sections.append(current_section)
 
    return sections


from langchain_text_splitters import RecursiveCharacterTextSplitter 
def chunk_sections(sections):
    splitter = RecursiveCharacterTextSplitter(
        chunk_size=500,
        chunk_overlap=80,
        separators=["\n\n", "\n", ".", " "]
    )
 
    chunks = []
 
    for sec in sections:
        split_texts = splitter.split_text(sec["content"])
 
        for i, chunk in enumerate(split_texts):
            chunks.append({
                "text": chunk,
                "metadata": {
                    "section": sec["title"],
                    "page_start": sec["page_start"],
                    "chunk_id": f"{sec['title']}_{i}"
                }
            })
 
    return chunks



def clean_text(chunk):
    # Remove excessive spaces
    text = re.sub(r'\s+', ' ', chunk)
    
    # Fix broken words (optional improvement)
    text = text.replace("- ", "")
    
    return text.strip()
def process_pdf(pdf_path):
    pages = extract_text_from_pdf(pdf_path)
    sections = split_into_sections(pages)
    chunks = chunk_sections(sections)
 
    # Clean + enrich
    final_chunks = []
    for c in chunks:
        c["text"] = clean_text(c["text"])
        
        final_chunks.append(c)
 
    return final_chunks

def get_embedding(text):
    response = client.embeddings.create(
        model="text-embedding-3-large",  # Foundry deployment name
        input=text
    )
    return response.data[0].embedding
 

def embed_chunks(chunks):
    embedded_chunks = []
 
    for c in chunks:
        embedding = get_embedding(c["text"])
 
        embedded_chunks.append({
            "text": c["text"],
            "embedding": embedding,
            "metadata": c["metadata"]
        })
 
    return embedded_chunks
 
 

chunks = process_pdf("FOSA_description.pdf")
embedded_chunks=embed_chunks(chunks)


import json

with open("embedded_chunks.json", "w", encoding="utf-8") as f:
    json.dump(embedded_chunks, f, ensure_ascii=False)
